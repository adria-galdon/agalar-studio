# Copia este archivo a .env.local y rellena lo que uses.
# Sin ninguna de estas variables, el formulario "Notifícame" sigue funcionando:
# valida el correo y registra el alta en el log del servidor.

# --- Opción A: Resend (recomendado) ---
# Crea una "Audience" en https://resend.com y pega aquí la API key y su ID.
# RESEND_API_KEY=re_xxxxxxxxxxxxxxxx
# NOTIFY_AUDIENCE_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# --- Opción B: cualquier webhook (Zapier, Make, tu backend…) ---
# Recibe un POST JSON: { email, source, at }
# SUBSCRIBE_WEBHOOK_URL=https://hooks.tuservicio.com/xxxxx
